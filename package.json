{
  "name": "@iwo-szapar/data-mcp",
  "version": "0.3.0",
  "description": "Unified data MCP server for Second Brain \u2014 PocketBase and Supabase adapters",
  "type": "module",
  "bin": {
    "data-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "files": [
    "dist/",
    "migrations/",
    "seed/"
  ],
  "keywords": [
    "mcp",
    "second-brain",
    "pocketbase",
    "supabase",
    "knowledge-management"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "pocketbase": "^0.25.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "tsx": "^4.19.4"
  }
}