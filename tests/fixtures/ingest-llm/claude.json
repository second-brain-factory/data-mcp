    "account": { "uuid": "22222222-aaaa-bbbb-cccc-000000000002" },
    "chat_messages": [
      {
        "uuid": "33333333-aaaa-bbbb-cccc-000000000011",
        "sender": "human",
        "content": [
          { "type": "text", "text": "Why does my ingress return 502 only for websocket upgrades?" }
        ],
        "created_at": "2026-04-11T14:00:05.000000Z",
        "updated_at": "2026-04-11T14:00:05.000000Z",
        "attachments": [],
        "files": []
      },
      {
        "uuid": "33333333-aaaa-bbbb-cccc-000000000012",
        "sender": "assistant",
        "content": [
          { "type": "text", "text": "Your nginx ingress is missing the upgrade headers. Add proxy-set-headers with Upgrade and Connection keys, then 502s on websocket upgrades stop." }
        ],
        "created_at": "2026-04-11T14:00:45.000000Z",
        "updated_at": "2026-04-11T14:00:45.000000Z",
        "attachments": [],
        "files": []
      }
