    "chat_messages": [
      {
        "uuid": "33333333-aaaa-bbbb-cccc-000000000003",
        "sender": "human",
        "text": "My sourdough starter smells like acetone after day 4. Is it dead?",
        "created_at": "2026-03-02T09:15:10.000000Z",
        "updated_at": "2026-03-02T09:15:10.000000Z",
        "attachments": [],
        "files": []
      },
      {
        "uuid": "33333333-aaaa-bbbb-cccc-000000000004",
        "sender": "assistant",
        "text": "Not dead — the acetone smell means it is hungry. Switch to twice-daily feedings at 1:1:1 and the smell should fade within two days.",
        "created_at": "2026-03-02T09:15:40.000000Z",
        "updated_at": "2026-03-02T09:15:40.000000Z",
        "attachments": [],
        "files": []
      },
      {
        "uuid": "33333333-aaaa-bbbb-cccc-000000000005",
        "sender": "human",
        "text": "Should I use rye flour for the feedings?",
        "created_at": "2026-03-02T09:30:00.000000Z",
        "updated_at": "2026-03-02T09:30:00.000000Z",
        "attachments": [],
        "files": []
      },
      {
        "uuid": "33333333-aaaa-bbbb-cccc-000000000006",
        "sender": "assistant",
        "text": "A 20% rye blend speeds recovery because rye carries more wild yeast and amylase.",
        "created_at": "2026-03-02T09:30:30.000000Z",
        "updated_at": "2026-03-02T09:30:30.000000Z",
        "attachments": [],
        "files": []
      }
    ]
  },
